{
  "name": "pyro-wiki-vscode-extension",
  "displayName": "PYRo Wiki",
  "description": "Safe Markdown preview, slash commands, cloud sync and collaboration for PYRo Wiki.",
  "version": "0.1.2",
  "publisher": "pyro-wiki",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Markdown"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:pyroWiki.selectWikiRoot",
    "onCommand:pyroWiki.openPreview",
    "onCommand:pyroWiki.openMarkdownWorkspace",
    "onView:pyroWiki.documents",
    "onWebviewPanel:pyroWikiPreview",
    "onCommand:pyroWiki.signIn",
    "onCommand:pyroWiki.signOut",
    "onCommand:pyroWiki.refreshCloudDocuments",
    "onCommand:pyroWiki.joinCollaboration",
    "onCommand:pyroWiki.leaveCollaboration",
    "onView:pyroWiki.cloudDocuments",
    "onView:pyroWiki.collaboration",
    "onUri",
    "onCommand:pyroWiki.viewCloudRevisions",
    "onCommand:pyroWiki.compareCloudDocument",
    "onCommand:pyroWiki.completeFeishuLogin",
    "onCommand:pyroWiki.saveDraft",
    "onCommand:pyroWiki.viewRevisions",
    "onCommand:pyroWiki.retrySyncQueue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pyroWiki.selectWikiRoot",
        "title": "PYRo Wiki: Select Wiki Root",
        "icon": "$(folder-opened)"
      },
      {
        "command": "pyroWiki.openPreview",
        "title": "PYRo Wiki: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "pyroWiki.pullDocument",
        "title": "PYRo Wiki: Pull Document",
        "icon": "$(cloud-download)"
      },
      {
        "command": "pyroWiki.pushDocument",
        "title": "PYRo Wiki: Push Document",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "pyroWiki.resolveConflict",
        "title": "PYRo Wiki: Resolve Conflict",
        "icon": "$(diff)"
      },
      {
        "command": "pyroWiki.joinCollaboration",
        "title": "PYRo Wiki: Join Collaboration",
        "icon": "$(broadcast)"
      },
      {
        "command": "pyroWiki.openSourceAndPreview",
        "title": "PYRo Wiki: Open Source + Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "pyroWiki.refreshPreview",
        "title": "PYRo Wiki: Refresh Preview",
        "icon": "$(refresh)"
      },
      {
        "command": "pyroWiki.pullRepository",
        "title": "PYRo Wiki: Pull Repository",
        "icon": "$(sync)"
      },
      {
        "command": "pyroWiki.repositoryStatus",
        "title": "PYRo Wiki: Show Repository Status",
        "icon": "$(info)"
      },
      {
        "command": "pyroWiki.openMarkdownWorkspace",
        "title": "PYRo Wiki: Show Markdown Workspace",
        "icon": "$(book)"
      },
      {
        "command": "pyroWiki.searchMarkdownDocuments",
        "title": "PYRo Wiki: Search Markdown Documents",
        "icon": "$(search)"
      },
      {
        "command": "pyroWiki.refreshDocuments",
        "title": "PYRo Wiki: Refresh Markdown Documents",
        "icon": "$(refresh)"
      },
      {
        "command": "pyroWiki.signIn",
        "title": "PYRo Wiki: Sign in with Feishu",
        "icon": "$(sign-in)"
      },
      {
        "command": "pyroWiki.signOut",
        "title": "PYRo Wiki: Sign out",
        "icon": "$(sign-out)"
      },
      {
        "command": "pyroWiki.refreshCloudDocuments",
        "title": "PYRo Wiki: Refresh Cloud Documents",
        "icon": "$(refresh)"
      },
      {
        "command": "pyroWiki.leaveCollaboration",
        "title": "PYRo Wiki: Leave Collaboration",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "pyroWiki.viewCloudRevisions",
        "title": "PYRo Wiki: View Cloud Revisions",
        "icon": "$(history)"
      },
      {
        "command": "pyroWiki.compareCloudDocument",
        "title": "PYRo Wiki: Compare Cloud Document",
        "icon": "$(compare-changes)"
      },
      {
        "command": "pyroWiki.completeFeishuLogin",
        "title": "PYRo Wiki: Complete Feishu Login",
        "icon": "$(key)"
      },
      {
        "command": "pyroWiki.saveDraft",
        "title": "PYRo Wiki: Save Cloud Draft",
        "icon": "$(save-as)"
      },
      {
        "command": "pyroWiki.viewRevisions",
        "title": "PYRo Wiki: View Current Revisions",
        "icon": "$(history)"
      },
      {
        "command": "pyroWiki.retrySyncQueue",
        "title": "PYRo Wiki: Retry Sync Queue",
        "icon": "$(sync)"
      }
    ],
    "configuration": {
      "title": "PYRo Wiki",
      "properties": {
        "pyroWiki.wikiRoot": {
          "type": "string",
          "default": "",
          "description": "Wiki root relative to the workspace, or an absolute path."
        },
        "pyroWiki.enablePreview": {
          "type": "boolean",
          "default": true
        },
        "pyroWiki.enableSlashCommands": {
          "type": "boolean",
          "default": true
        },
        "pyroWiki.enableCloudSync": {
          "type": "boolean",
          "default": true
        },
        "pyroWiki.enableCollaboration": {
          "type": "boolean",
          "default": true
        },
        "pyroWiki.apiBaseUrl": {
          "type": "string",
          "default": "https://pyro-wiki-api.luckyy.ccwu.cc",
          "description": "PYRo Wiki Worker API base URL."
        },
        "pyroWiki.authorCacheTtlMinutes": {
          "type": "number",
          "default": 60
        },
        "pyroWiki.lockPreviewLayout": {
          "type": "boolean",
          "default": true,
          "description": "Keep Wiki source Markdown in the left editor column and PYRo preview in the right column."
        },
        "pyroWiki.followActiveMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "Update the PYRo preview when a different Wiki Markdown file becomes active."
        },
        "pyroWiki.syncUnsavedPreview": {
          "type": "boolean",
          "default": true,
          "description": "Save dirty Markdown documents before reloading the full VitePress preview so source and preview cannot diverge."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "pyroWiki.openSourceAndPreview",
          "when": "editorLangId == markdown",
          "group": "navigation@9"
        },
        {
          "command": "pyroWiki.openPreview",
          "when": "editorLangId == markdown",
          "group": "navigation@10"
        },
        {
          "command": "pyroWiki.pushDocument",
          "when": "editorLangId == markdown",
          "group": "navigation@11"
        },
        {
          "command": "pyroWiki.pullDocument",
          "when": "editorLangId == markdown",
          "group": "navigation@12"
        },
        {
          "command": "pyroWiki.saveDraft",
          "when": "editorLangId == markdown",
          "group": "navigation@13"
        },
        {
          "command": "pyroWiki.viewRevisions",
          "when": "editorLangId == markdown",
          "group": "navigation@14"
        },
        {
          "command": "pyroWiki.retrySyncQueue",
          "when": "editorLangId == markdown",
          "group": "navigation@15"
        }
      ],
      "view/title": [
        {
          "command": "pyroWiki.openMarkdownWorkspace",
          "when": "view == pyroWiki.documents",
          "group": "navigation@1"
        },
        {
          "command": "pyroWiki.refreshDocuments",
          "when": "view == pyroWiki.documents",
          "group": "navigation@2"
        },
        {
          "command": "pyroWiki.searchMarkdownDocuments",
          "when": "view == pyroWiki.documents",
          "group": "navigation@3"
        },
        {
          "command": "pyroWiki.signIn",
          "when": "view == pyroWiki.cloudDocuments",
          "group": "navigation@1"
        },
        {
          "command": "pyroWiki.signOut",
          "when": "view == pyroWiki.cloudDocuments",
          "group": "navigation@2"
        },
        {
          "command": "pyroWiki.refreshCloudDocuments",
          "when": "view == pyroWiki.cloudDocuments",
          "group": "navigation@3"
        },
        {
          "command": "pyroWiki.joinCollaboration",
          "when": "view == pyroWiki.collaboration",
          "group": "navigation@1"
        },
        {
          "command": "pyroWiki.leaveCollaboration",
          "when": "view == pyroWiki.collaboration",
          "group": "navigation@2"
        }
      ],
      "view/item": [
        {
          "command": "pyroWiki.viewCloudRevisions",
          "when": "view == pyroWiki.cloudDocuments && viewItem == pyroWiki.cloudDocument",
          "group": "inline@1"
        },
        {
          "command": "pyroWiki.compareCloudDocument",
          "when": "view == pyroWiki.cloudDocuments && viewItem == pyroWiki.cloudDocument",
          "group": "inline@1"
        }
      ]
    },
    "markdown.markdownItPlugins": true,
    "views": {
      "pyroWiki": [
        {
          "id": "pyroWiki.documents",
          "name": "Markdown Documents",
          "contextualTitle": "PYRo Wiki Markdown documents",
          "icon": "$(book)"
        },
        {
          "id": "pyroWiki.cloudDocuments",
          "name": "Cloud Documents",
          "contextualTitle": "PYRo Wiki cloud documents",
          "icon": "$(cloud)"
        },
        {
          "id": "pyroWiki.collaboration",
          "name": "Collaboration",
          "contextualTitle": "PYRo Wiki collaboration",
          "icon": "$(broadcast)"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pyroWiki",
          "title": "PYRo Wiki",
          "icon": "./media/pyro-wiki.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pyroWiki.documents",
        "contents": "PYRo Wiki Markdown workspace\n\n[Show Markdown Workspace](command:pyroWiki.openMarkdownWorkspace)  [Refresh](command:pyroWiki.refreshDocuments)"
      }
    ]
  },
  "scripts": {
    "compile": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run compile && vsce package --no-dependencies",
    "install-local": "npm run package && code --install-extension pyro-wiki-vscode-extension-0.1.2.vsix --force"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "yjs": "^13.6.27",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@types/ws": "^8.5.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhou-ee/PYRo-Wiki.git"
  }
}
