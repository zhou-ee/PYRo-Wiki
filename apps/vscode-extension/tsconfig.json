{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "lib":  [
                                        "ES2022",
                                        "DOM"
                                    ],
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "rootDir":  ".",
                            "outDir":  "dist",
                            "types":  [
                                          "node",
                                          "vscode"
                                      ]
                        },
    "include":  [
                    "src/**/*.ts",
                    "test/**/*.ts"
                ]
}
